<%- include('layouts/auth/head.ejs') %>

<nav class="navbar navbar-expand-lg landing-navbar sticky-top">
  <div class="container">
    <a class="navbar-brand fw-bold text-primary d-flex align-items-center" href="/">
      <img src="/img/main-logo.png" alt="Projexly" height="40" class="me-2">
    </a>
    <div class="ms-auto">
      <% if (userAuth) { %>
        <a href="/dashboard" class="btn btn-primary px-4">Go to Dashboard</a>
      <% } else { %>
        <a href="/auth" class="btn btn-outline-primary me-2 px-4">Login</a>
        <a href="/auth/signup" class="btn btn-primary px-4">Sign Up</a>
      <% } %>
    </div>
  </div>
</nav>

<section class="hero-section">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-6 mb-5 mb-lg-0">
        <h1 class="hero-title">Manage and Showcase Your Projects Easily</h1>
        <p class="hero-subtitle">
          Projexly is a modern portfolio management tool designed for developers.
          Keep track of your projects, tasks, and skills in one place, and access them anywhere via our API.
        </p>
        <div class="d-flex">
          <% if (userAuth) { %>
            <a href="/dashboard" class="btn btn-primary btn-lg px-5 py-3 me-3">Go to Dashboard</a>
          <% } else { %>
            <a href="/auth/signup" class="btn btn-primary btn-lg px-5 py-3 me-3">Get Started</a>
            <a href="#how-it-works" class="btn btn-light btn-lg px-5 py-3">Learn More</a>
          <% } %>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="card shadow-lg border-0 rounded-lg overflow-hidden">
          <img src="img/photos/hero.png" class="img-fluid" alt="Dashboard Preview">
          <div class="card-img-overlay d-flex align-items-center justify-content-center text-white" style="background: rgba(0,0,0,0.1)">
             <!-- Overlay content if needed -->
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section-padding bg-white" id="features">
  <div class="container">
    <div class="text-center mb-5">
      <h2 class="fw-bold h1">Everything You Need</h2>
      <p class="text-muted">Simple, powerful tools to manage your professional data.</p>
    </div>
    <div class="row g-4">
      <div class="col-md-6 col-lg-3">
        <div class="card feature-card shadow-sm">
          <div class="feature-icon">
            <i data-feather="package"></i>
          </div>
          <h4 class="fw-bold">Manage Projects</h4>
          <p class="text-muted mb-0">Create and organize your project portfolio with descriptions, stacks, and demo links.</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-3">
        <div class="card feature-card shadow-sm">
          <div class="feature-icon">
            <i data-feather="check-square"></i>
          </div>
          <h4 class="fw-bold">Track Tasks</h4>
          <p class="text-muted mb-0">Break down your projects into actionable tasks and monitor your progress in real-time.</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-3">
        <div class="card feature-card shadow-sm">
          <div class="feature-icon">
            <i data-feather="code"></i>
          </div>
          <h4 class="fw-bold">Skill Matrix</h4>
          <p class="text-muted mb-0">Maintain a list of your technical skills and expertise levels for quick reference.</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-3">
        <div class="card feature-card shadow-sm">
          <div class="feature-icon">
            <i data-feather="database"></i>
          </div>
          <h4 class="fw-bold">Developer API</h4>
          <p class="text-muted mb-0">Access your portfolio data via secure JSON endpoints to use in your own websites.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section-padding bg-light" id="how-it-works">
  <div class="container">
    <div class="text-center mb-5">
      <h2 class="fw-bold h1">How It Works</h2>
      <p class="text-muted">A simple workflow from creation to integration.</p>
    </div>
    <div class="row justify-content-center">
      <div class="col-md-4">
        <div class="how-it-works-step">
          <div class="step-number">1</div>
          <h4 class="fw-bold">Add Your Data</h4>
          <p class="text-muted">Enter your projects, skills, and tasks through our intuitive dashboard interface.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="how-it-works-step">
          <div class="step-number">2</div>
          <h4 class="fw-bold">Organize & Track</h4>
          <p class="text-muted">Keep your portfolio up-to-date by tracking progress and updating project details.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="how-it-works-step">
          <div class="step-number">3</div>
          <h4 class="fw-bold">Integrate Anywhere</h4>
          <p class="text-muted">Use our API to display your latest work on your personal website or LinkedIn.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section-padding bg-white" id="api">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-6 mb-5 mb-lg-0">
        <h2 class="fw-bold h1 mb-4">Powerful API Support</h2>
        <p class="hero-subtitle">
          We provide clean JSON endpoints for your projects and skills.
          Perfect for building headless portfolios or integrating with other tools.
        </p>
        <ul class="list-unstyled mb-4">
          <li class="mb-3 d-flex align-items-center">
            <i class="text-primary me-2" data-feather="check-circle"></i>
            <span>GET <code>/api/projects</code> - List all projects</span>
          </li>
          <li class="mb-3 d-flex align-items-center">
            <i class="text-primary me-2" data-feather="check-circle"></i>
            <span>GET <code>/api/skills</code> - List all skills</span>
          </li>
        </ul>
      </div>
      <div class="col-lg-6">
        <div class="api-preview shadow">
<pre class="mb-0">
{
  <span class="json-key">"status"</span>: <span class="json-value">"success"</span>,
  <span class="json-key">"data"</span>: [
    {
      <span class="json-key">"title"</span>: <span class="json-value">"Project Alpha"</span>,
      <span class="json-key">"stacks"</span>: [<span class="json-value">"Node.js"</span>, <span class="json-value">"React"</span>],
      <span class="json-key">"progress"</span>: <span class="json-value">85</span>
    }
  ]
}</pre>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section-padding bg-primary-slate text-white text-center my-0">
  <div class="container">
    <h2 class="fw-bold text-light h1 mb-4">Start Managing Your Portfolio Today</h2>
    <p class="lead mb-5 opacity-75">Join our platform and take control of your developer showcase.</p>
    <div class="d-flex justify-content-center">
      <% if (userAuth) { %>
        <a href="/dashboard" class="btn btn-light btn-lg px-5 py-3">Go to Dashboard</a>
      <% } else { %>
        <a href="/auth/signup" class="btn btn-light btn-lg px-5 py-3 me-3">Create Free Account</a>
        <a href="/auth" class="btn btn-outline-light btn-lg px-5 py-3">Login to Your Account</a>
      <% } %>
    </div>
  </div>
</section>

<footer class="py-4 bg-primary-dark">
  <div class="container text-center">
    <p class="text-light mb-0">&copy; 2026 Projexly. Built for Developers.</p>
  </div>
</footer>

<%- include('layouts/auth/footer.ejs') %>
