<%- include('../layouts/auth/head.ejs') %>

<main class="d-flex w-100 bg-light">
  <div class="container d-flex flex-column py-4 py-md-5">
    <div class="row justify-content-center">
      <div class="col-12 col-sm-10 col-md-8 col-lg-5 col-xl-4">
        <div class="text-center mb-4">
          <a href="/" class="d-inline-block mb-4">
            <img src="/img/main-logo.png" alt="Projexly" height="50">
          </a>
          <h1 class="h3 auth-title mb-2">Sign in</h1>
          <p class="auth-subtitle mb-0">Projexly — your modern portfolio dashboard</p>
        </div>

        <div class="card auth-card">
          <div class="card-body p-4 p-sm-5">
            <% if (flashdata && flashdata.length) { %>
              <% flashdata.forEach(function (item) { %>
                <div class="alert alert-<%= item.type || 'info' %> alert-dismissible fade show mb-3" role="alert">
                  <%= item.message %>
                  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
              <% }); %>
            <% } %>

            <% if (errors && errors?.name !== "Validation") { %>
              <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
                <i class="align-middle me-2" data-feather="alert-triangle"></i>
                <%= errors?.message %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
              </div>
            <% } %>

            <%- include('./partials/google-oauth-button.ejs', { googleLabel: 'Sign in with Google' }) %>

            <div class="auth-divider"><span>or with email</span></div>

            <form action="/auth" method="post" novalidate>
              <div class="mb-3">
                <label class="form-label fw-semibold" for="signin-email">Email</label>
                <input id="signin-email" class="form-control form-control-lg" type="email" name="email" autocomplete="email"
                  placeholder="you@example.com" value="<%= values && values?.email || '' %>" />
                <% if (errors && errors?.validation?.email) { %>
                  <small class="text-danger d-block mt-1"><%= errors?.validation?.email?.message[0] %></small>
                <% } %>
              </div>
              <div class="mb-4">
                <label class="form-label fw-semibold" for="signin-password">Password</label>
                <input id="signin-password" class="form-control form-control-lg" type="password" name="password" autocomplete="current-password"
                  placeholder="Enter your password" value="<%= values && values?.password || '' %>" />
                <% if (errors && errors?.validation?.password) { %>
                  <small class="text-danger d-block mt-1"><%= errors?.validation?.password?.message[0] %></small>
                <% } %>
              </div>
              <button type="submit" class="btn btn-lg btn-primary w-100">Sign in</button>
            </form>

            <p class="text-center auth-footer-link text-muted mt-4 mb-0">
              Don’t have an account? <a href="/auth/signup" class="fw-semibold text-decoration-none">Create one</a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('../layouts/auth/footer.ejs') %>
