<%- include('layouts/head.ejs') %>

<main class="content">
  <div class="container-fluid p-0">

    <h1 class="h3 mb-3">Dashboard</h1>

    <!-- Row 1: Summary Cards -->
    <div class="row">
      <div class="col-sm-6 col-xl-3 d-flex">
        <div class="card flex-fill">
          <div class="card-body">
            <div class="row">
              <div class="col mt-0">
                <h5 class="card-title">Total Projects</h5>
              </div>
              <div class="col-auto">
                <div class="stat text-primary">
                  <i class="align-middle" data-feather="briefcase"></i>
                </div>
              </div>
            </div>
            <h1 class="mt-1 mb-3"><%= stats.totalProjects %></h1>
            <div class="mb-0">
              <span class="text-muted">Manage your portfolio</span>
            </div>
          </div>
        </div>
      </div>

      <div class="col-sm-6 col-xl-3 d-flex">
        <div class="card flex-fill">
          <div class="card-body">
            <div class="row">
              <div class="col mt-0">
                <h5 class="card-title">Completed Tasks</h5>
              </div>
              <div class="col-auto">
                <div class="stat text-success">
                  <i class="align-middle" data-feather="check-square"></i>
                </div>
              </div>
            </div>
            <h1 class="mt-1 mb-3"><%= stats.completedTasks %></h1>
            <div class="mb-0">
              <span class="text-success"> <i class="mdi mdi-arrow-bottom-right"></i> <%= stats.completionRate %>% </span>
              <span class="text-muted">Completion rate</span>
            </div>
          </div>
        </div>
      </div>

      <div class="col-sm-6 col-xl-3 d-flex">
        <div class="card flex-fill">
          <div class="card-body">
            <div class="row">
              <div class="col mt-0">
                <h5 class="card-title">Total Tasks</h5>
              </div>
              <div class="col-auto">
                <div class="stat text-warning">
                  <i class="align-middle" data-feather="list"></i>
                </div>
              </div>
            </div>
            <h1 class="mt-1 mb-3"><%= stats.totalTasks %></h1>
            <div class="mb-0">
              <span class="text-muted">Active and completed</span>
            </div>
          </div>
        </div>
      </div>

      <div class="col-sm-6 col-xl-3 d-flex">
        <div class="card flex-fill">
          <div class="card-body">
            <div class="row">
              <div class="col mt-0">
                <h5 class="card-title">Total Skills</h5>
              </div>
              <div class="col-auto">
                <div class="stat text-info">
                  <i class="align-middle" data-feather="award"></i>
                </div>
              </div>
            </div>
            <h1 class="mt-1 mb-3"><%= stats.totalSkills %></h1>
            <div class="mb-0">
              <span class="text-muted">Technical expertise</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Row 2: Project Overview & Recent Projects -->
    <div class="row">
      <div class="col-12 col-lg-4 col-xxl-3 d-flex">
        <div class="card flex-fill w-100">
          <div class="card-header">
            <h5 class="card-title mb-0">Calendar</h5>
          </div>
          <div class="card-body d-flex">
            <div class="align-self-center w-100">
              <div class="chart">
                <div id="datetimepicker-dashboard"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="col-12 col-lg-8 col-xxl-9 d-flex">
        <div class="card flex-fill w-100">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0">Recent Projects</h5>
            <a href="/projects" class="btn btn-sm btn-primary">View All</a>
          </div>
          <div class="card-body py-3">
            <div class="table-responsive">
              <table class="table table-hover my-0">
                <thead>
                  <tr>
                    <th>Project</th>
                    <th class="d-none d-md-table-cell">Tech Stack</th>
                    <th class="d-none d-xl-table-cell">Status</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (recentProjects && recentProjects.length > 0) { %>
                    <% recentProjects.forEach(project => { %>
                      <tr>
                        <td>
                          <div class="d-flex align-items-center">
                            <img src="<%= project.image || '/img/photos/unsplash-1.jpg' %>" class="rounded me-3" width="40" height="40" style="object-fit: cover;">
                            <div>
                              <a href="/projects/<%= project._id %>/edit" class="text-dark fw-bold text-decoration-none"><%= project.title %></a>
                              <div class="text-muted small"><%= dayjs(project.updatedAt).fromNow() %></div>
                            </div>
                          </div>
                        </td>
                        <td class="d-none d-md-table-cell">
                          <% if (project.stacks && project.stacks.length > 0) { %>
                            <div class="d-flex flex-wrap gap-1">
                              <% project.stacks.slice(0, 3).forEach(stack => { %>
                                <span class="badge bg-light text-dark border"><%= stack %></span>
                              <% }) %>
                              <% if (project.stacks.length > 3) { %>
                                <span class="badge bg-light text-dark border">+<%= project.stacks.length - 3 %></span>
                              <% } %>
                            </div>
                          <% } else { %>
                            <span class="text-muted small">No stack</span>
                          <% } %>
                        </td>
                        <td class="d-none d-xl-table-cell">
                          <%
                            let badgeClass = 'bg-secondary';
                            if (project.status === 'FINISHED') badgeClass = 'bg-success';
                            else if (project.status === 'PROGRESS') badgeClass = 'bg-warning';
                            else if (project.status === 'ON_HOLD') badgeClass = 'bg-danger';
                          %>
                          <span class="badge <%= badgeClass %>">
                            <%= project.status %>
                          </span>
                        </td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr>
                      <td colspan="3" class="text-center py-4">
                        <div class="text-muted mb-2">No projects yet</div>
                        <form action="/projects" method="POST" class="d-inline">
                          <button type="submit" class="btn btn-sm btn-outline-primary">Create your first project</button>
                        </form>
                      </td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Row 3: Upcoming Tasks & Skills -->
    <div class="row">
      <div class="col-12 col-lg-8 col-xxl-9 d-flex">
        <div class="card flex-fill w-100">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0">Tasks Overview</h5>
          </div>
          <div class="card-body px-4">
             <div class="mb-4">
               <h6 class="text-muted mb-3"><i class="align-middle me-1 text-warning" data-feather="clock"></i> Pending Tasks</h6>
               <% if (pendingTasks && pendingTasks.length > 0) { %>
                 <ul class="list-group list-group-flush">
                   <% pendingTasks.forEach(task => { %>
                     <li class="list-group-item px-0 border-0 d-flex justify-content-between align-items-center mb-2">
                       <div class="me-auto">
                         <div class="fw-bold"><%= task.note %></div>
                         <small class="text-muted"><%= task.project ? task.project.title : 'No Project' %></small>
                       </div>
                       <div class="text-end" style="min-width: 60px;">
                         <div class="text-muted small mb-1 text-center"><%= task.projectProgress %>%</div>

                         <div class="progress progress-sm">
                           <div class="progress-bar bg-primary" role="progressbar" style="width: <%= task.projectProgress %>%;" aria-valuenow="<%= task.projectProgress %>" aria-valuemin="0" aria-valuemax="100"></div>
                         </div>
                       </div>
                     </li>
                   <% }) %>
                 </ul>
               <% } else { %>
                 <div class="text-muted small">No pending tasks. Great job!</div>
               <% } %>
             </div>

             <hr>

             <div class="mt-4">
               <h6 class="text-muted mb-3"><i class="align-middle me-1 text-success" data-feather="check-circle"></i> Recently Completed</h6>
               <% if (doneTasks && doneTasks.length > 0) { %>
                 <ul class="list-group list-group-flush">
                   <% doneTasks.forEach(task => { %>
                     <li class="list-group-item px-0 border-0 d-flex justify-content-between align-items-center mb-1 opacity-75">
                       <div class="me-auto">
                         <div class="text-decoration-line-through"><%= task.note %></div>
                         <small class="text-muted"><%= task.project ? task.project.title : 'No Project' %></small>
                       </div>
                       <i class="align-middle text-success" data-feather="check"></i>
                     </li>
                   <% }) %>
                 </ul>
               <% } else { %>
                 <div class="text-muted small">No tasks completed recently.</div>
               <% } %>
             </div>
          </div>
        </div>
      </div>

      <div class="col-12 col-lg-4 col-xxl-3">
        <div class="card w-100">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0">Skills Snapshot</h5>
            <a href="/skills" class="btn btn-sm btn-link text-primary p-0">Manage</a>
          </div>
          <div class="card-body">
            <% if (skills && skills.length > 0) { %>
              <div class="d-flex flex-wrap gap-2">
                <% skills.forEach(skill => { %>
                  <span class="badge bg-light text-dark border px-3 py-2 rounded-pill">
                    <%= skill.name %>
                  </span>
                <% }) %>
              </div>
            <% } else { %>
              <div class="text-center py-4">
                <p class="text-muted small mb-3">Highlight your technical stack</p>
                <a href="/skills" class="btn btn-sm btn-primary">Add Skills</a>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>

  </div>
</main>

<%- include('layouts/end.ejs') %>