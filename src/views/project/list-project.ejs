<%- include('../layouts/head.ejs') %>
<main class="content">
  <div class="container-fluid p-0">

    <div class="mb-3 d-flex justify-content-between align-items-center">
      <h1 class="h3 mb-0">Projects</h1>
      <form action="/projects" method="post">
        <button type="submit" class="btn btn-primary shadow-sm">
          <i class="align-middle me-2" data-feather="plus"></i> New Project
        </button>
      </form>
    </div>

    <%- include('../includes/alert.ejs') %>

    <div class="row">
      <% if(projects.length === 0) { %>
      <div class="col-12 text-center py-5">
        <div class="card p-5 shadow-sm border-0">
          <div class="card-body">
            <div class="mb-4">
              <div class="bg-light d-inline-block p-4 rounded-circle">
                <i class="align-middle text-muted" data-feather="package" style="width: 48px; height: 48px;"></i>
              </div>
            </div>
            <h3 class="h4">No projects yet</h3>
            <p class="text-muted mb-4">Start your journey by adding your first project to your portfolio.</p>
            <form action="/projects" method="post">
              <button type="submit" class="btn btn-primary btn-lg px-4">
                <i class="align-middle me-2" data-feather="plus-circle"></i> Create Project
              </button>
            </form>
          </div>
        </div>
      </div>
      <% } else { %>
      <% projects.forEach(project => { %>
      <div class="col-12 col-md-6 col-lg-4 mb-4">
        <div class="card h-100 shadow-sm border-0 project-card hover-shadow transition-all">
          <div class="position-relative">
            <img src="<%= project.image || '/img/photos/project-0.png' %>" onerror="this.src='/img/photos/project-0.png'" class="card-img-top" alt="<%= project.title %>" style="height: 180px; object-fit: cover;">
            <div class="position-absolute top-0 end-0 p-2">
              <% if(project.isSelected) { %>
              <span class="badge bg-primary shadow-sm">
                <i class="align-middle" data-feather="star" style="width: 12px; height: 12px;"></i> Featured
              </span>
              <% } %>
            </div>
            <div class="position-absolute bottom-0 start-0 p-2">
              <%
                const statusConfig = {
                  TODO: { class: 'bg-info', label: 'Todo' },
                  PROGRESS: { class: 'bg-warning', label: 'In Progress' },
                  ON_HOLD: { class: 'bg-danger', label: 'On Hold' },
                  FINISHED: { class: 'bg-success', label: 'Finished' },
                }
                const status = project.progress?.percentage >= 100 ? 'FINISHED' : project.status;
                const config = statusConfig[status] || statusConfig.TODO;
              %>
              <span class="badge <%= config.class %> shadow-sm"><%= config.label %></span>
            </div>
          </div>

          <div class="card-body d-flex flex-column p-4">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <h5 class="card-title h5 mb-0 text-truncate" title="<%= project.title %>">
                <a href="/projects/<%= project._id %>" class="text-dark text-decoration-none fw-bold"><%= project.title %></a>
              </h5>
              <div class="dropdown">
                <a href="#" data-bs-toggle="dropdown" class="text-muted p-1">
                  <i class="align-middle" data-feather="more-vertical"></i>
                </a>
                <div class="dropdown-menu dropdown-menu-end shadow border-0">
                  <a class="dropdown-item py-2" href="/projects/<%= project._id %>">
                    <i class="align-middle me-2 text-primary" data-feather="eye"></i> View Details
                  </a>
                  <a class="dropdown-item py-2" href="/projects/<%= project._id %>/edit">
                    <i class="align-middle me-2 text-info" data-feather="edit-2"></i> Edit Project
                  </a>
                  <div class="dropdown-divider"></div>
                  <a class="dropdown-item py-2 text-danger" id="action-delete-project" href="#" data-title="<%= project.title %>" data-projectId="<%= project._id %>">
                    <i class="align-middle me-2" data-feather="trash-2"></i> Delete
                  </a>
                </div>
              </div>
            </div>

            <div class="text-muted small mb-3">
              <i class="align-middle me-1" data-feather="calendar" style="width: 14px;"></i> <%= project.year || 'N/A' %>
            </div>

            <p class="card-text text-muted mb-4 small flex-grow-1" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; min-height: 2.5rem;">
              <%= project.description || 'No description provided.' %>
            </p>

            <div class="mb-4">
              <% if(project.stacks && project.stacks.length > 0) { %>
              <div class="d-flex flex-wrap gap-1">
                <% project.stacks.slice(0, 4).forEach(stack => { %>
                <span class="badge bg-light text-dark border"><%= stack %></span>
                <% }) %>
                <% if(project.stacks.length > 4) { %>
                <span class="badge bg-light text-dark border">+<%= project.stacks.length - 4 %></span>
                <% } %>
              </div>
              <% } %>
            </div>

            <div class="mt-auto">
              <div class="d-flex justify-content-between align-items-center mb-1">
                <span class="small fw-bold">Progress</span>
                <span class="small text-muted"><%= status === 'FINISHED' ? 100 : project.progress?.percentage || 0 %>%</span>
              </div>
              <div class="progress progress-sm" style="height: 6px;">
                <div class="progress-bar bg-primary" role="progressbar" style="width: <%= status === 'FINISHED' ? 100 : project.progress?.percentage || 0 %>%;" aria-valuenow="<%= project.progress?.percentage || 0 %>" aria-valuemin="0" aria-valuemax="100"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <% }) %>
      <% } %>
    </div>

  </div>
</main>

<!-- Delete Modal -->
<div class="modal fade shadow" id="modalDeleteProject" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="modalDeleteProjectLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title fw-bold" id="modalDeleteProjectLabel">Delete Project</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body text-center py-4">
        <div class="mb-3 text-danger">
          <i data-feather="alert-triangle" style="width: 48px; height: 48px;"></i>
        </div>
        <h4 class="mb-2">Are you sure?</h4>
        <p class="text-muted">You are about to delete <strong id="delete-project-name">this project</strong>. This action cannot be undone and will delete all associated tasks.</p>
      </div>

      <div class="modal-footer border-0 d-flex justify-content-center pb-4">
        <form action="/projects" id="modalDeleteProjectForm" method="post">
          <input type="hidden" name="_method" value="DELETE">
          <button type="button" class="btn btn-light px-4 me-2" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-danger px-4">Yes, Delete Project</button>
        </form>
      </div>
    </div>
  </div>
</div>

<style>
  .project-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
  }
  .transition-all {
    transition: all 0.3s ease;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const deleteButtons = document.querySelectorAll('#action-delete-project');
    const deleteForm = document.getElementById('modalDeleteProjectForm');
    const deleteProjectName = document.getElementById('delete-project-name');

    deleteButtons.forEach(btn => {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        const projectId = this.dataset.projectid;
        const title = this.dataset.title;

        deleteForm.action = '/projects/' + projectId;
        deleteProjectName.innerText = title;

        const modal = new bootstrap.Modal(document.getElementById('modalDeleteProject'));
        modal.show();
      });
    });
  });
</script>

<%- include('../layouts/end.ejs') %>